LISTEN_ADDR=0.0.0.0:19000
COS_REGION=your-cos-region
COS_BUCKET=your-cos-bucket-appid
COS_ENDPOINT=https://your-cos-bucket-appid.cos.your-cos-region.myqcloud.com
COS_SECRET_ID=replace-with-secret-id
COS_SECRET_KEY=replace-with-secret-key
SPOOL_DIR=/spool
SHUTDOWN_TIMEOUT=30s
LIST_RETRY_ATTEMPTS=5
LIST_RETRY_INITIAL_DELAY=100ms
LIST_RETRY_MAX_DELAY=2s
UPLOAD_DATA_CACHE_TTL=10m
